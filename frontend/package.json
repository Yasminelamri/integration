    "@angular/platform-browser-dynamic": "^21.2.8",
    "@angular/router": "^21.1.0",
    "@angular/ssr": "^21.1.4",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "chart.js": "^4.5.1",
    "keycloak-js": "^26.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
