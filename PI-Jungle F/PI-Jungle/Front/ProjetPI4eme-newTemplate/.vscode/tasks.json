{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Angular: serve",
      "type": "shell",
      "command": "npm run start",
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "FORCE_COLOR": "1"
        }
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Local:|localhost:4200|Application bundle generation complete"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Angular: npm install",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    }
  ]
}
